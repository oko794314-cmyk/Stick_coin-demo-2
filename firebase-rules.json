{
  "rules": {
    "users": {
      "$username": {
        // Користувач може читати/писати лише свої дані
        ".read": "auth.uid === $username || root.child('admins').child(auth.uid).exists()",
        ".write": "auth.uid === $username",
        
        "password": {
          ".read": "auth.uid === $username",
          ".write": "auth.uid === $username"
        },
        "balance": {
          ".read": true,
          ".write": "auth.uid === $username && newData.val() >= 0"
        },
        "friends": {
          ".read": "auth.uid === $username",
          ".write": "auth.uid === $username"
        },
        "friendRequests": {
          ".read": "auth.uid === $username",
          ".write": "auth.uid === $username"
        },
        "gameInvitations": {
          ".read": "auth.uid === $username",
          ".write": false
        },
        "mining": {
          ".write": "auth.uid === $username"
        },
        "miningUpdatedAt": {
          ".write": "auth.uid === $username"
        },
        "avatar": {
          ".read": true,
          ".write": "auth.uid === $username"
        },
        "displayName": {
          ".read": true,
          ".write": "auth.uid === $username"
        },
        "online": {
          ".read": true,
          ".write": "auth.uid === $username"
        }
      }
    },
    "chats": {
      "$chatKey": {
        ".read": "root.child('chats').child($chatKey).child('messages').child('0').exists()",
        ".write": "auth.uid !== null",
        
        "messages": {
          "$messageId": {
            ".validate": "newData.child('text').isString() && newData.child('from').val() === auth.uid && newData.child('timestamp').exists()"
          }
        }
      }
    },
    "rpsMatches": {
      "$matchId": {
        ".read": "data.child('player1').val() === auth.uid || data.child('player2').val() === auth.uid",
        ".write": false,
        
        "choice1": {
          ".write": "root.child('rpsMatches').child($matchId).child('player1').val() === auth.uid"
        },
        "choice2": {
          ".write": "root.child('rpsMatches').child($matchId).child('player2').val() === auth.uid"
        }
      }
    },
    "transactions": {
      "$transactionId": {
        ".read": "data.child('from').val() === auth.uid || data.child('to').val() === auth.uid",
        ".write": false,
        
        ".validate": "newData.child('amount').isNumber() && newData.child('amount').val() > 0"
      }
    },
    "news": {
      "$newsId": {
        ".read": true,
        ".write": "root.child('admins').child(auth.uid).exists()"
      }
    }
  }
}
